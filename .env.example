# ──────────────────────────────────────────────────────────────────────────────
# .env.example — SAFE TO COMMIT. Shows teammates what variables are needed.
# Copy this to .env and fill in real values. Never commit the real .env file.
# ──────────────────────────────────────────────────────────────────────────────

# Neon PostgreSQL connection string — get from Neon dashboard → Connection Details
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&channel_binding=require"

# Optional: same connection string for direct psql CLI use
PSQL_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&channel_binding=require"

# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace_with_a_long_random_secret_at_least_32_chars"

# Server port
PORT=3000
